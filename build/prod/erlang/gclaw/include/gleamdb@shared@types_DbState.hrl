-record(db_state, {
    adapter :: gleamdb@storage:storage_adapter(),
    eavt :: gleam@dict:dict(gleamdb@fact:entity_id(), list(gleamdb@fact:datom())),
    aevt :: gleam@dict:dict(binary(), list(gleamdb@fact:datom())),
    avet :: gleam@dict:dict(binary(), gleam@dict:dict(gleamdb@fact:value(), gleamdb@fact:entity_id())),
    latest_tx :: integer(),
    subscribers :: list(gleam@erlang@process:subject(list(gleamdb@fact:datom()))),
    schema :: gleam@dict:dict(binary(), gleamdb@fact:attribute_config()),
    functions :: gleam@dict:dict(binary(), fun((gleamdb@shared@types:db_state(), integer(), integer(), list(gleamdb@fact:value())) -> list({gleamdb@fact:eid(),
        binary(),
        gleamdb@fact:value()}))),
    composites :: list(list(binary())),
    reactive_actor :: gleam@erlang@process:subject(gleamdb@shared@types:reactive_message()),
    followers :: list(gleam@erlang@process:pid_()),
    is_distributed :: boolean(),
    ets_name :: gleam@option:option(binary()),
    raft_state :: gleamdb@raft:raft_state(),
    vec_index :: gleamdb@vec_index:vec_index(),
    bm25_indices :: gleam@dict:dict(binary(), gleamdb@index@bm25:b_m25_index()),
    art_index :: gleamdb@index@art:art(),
    registry :: gleam@dict:dict(binary(), gleamdb@shared@types:index_adapter()),
    extensions :: gleam@dict:dict(binary(), gleamdb@shared@types:extension_instance()),
    predicates :: gleam@dict:dict(binary(), fun((gleamdb@fact:value()) -> boolean())),
    stored_rules :: list(gleamdb@shared@types:rule()),
    virtual_predicates :: gleam@dict:dict(binary(), fun((list(gleamdb@fact:value())) -> list(list(gleamdb@fact:value())))),
    config :: gleamdb@shared@types:config()
}).
